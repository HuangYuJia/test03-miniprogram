.top {
  padding: 22rpx 22rpx 18rpx;
  margin-top: 8rpx;
}

.topRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

.searchBtn {
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 39, 0.06);
  color: #111827;
  font-size: 26rpx;
}

.subtitle {
  margin-top: 10rpx;
  font-size: 26rpx;
}

.sectionHeader {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin: 28rpx 2rpx 14rpx;
}

.sectionTitle {
  font-size: 28rpx;
  font-weight: 700;
}

.adminEntry {
  font-size: 26rpx;
  color: #111827;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(17, 24, 39, 0.12);
  background: #fff;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.cat {
  padding: 22rpx;
}

.catName {
  font-size: 30rpx;
  font-weight: 700;
}

.catHint {
  margin-top: 10rpx;
  font-size: 24rpx;
}

.empty {
  padding: 28rpx 22rpx;
}

.emptyTitle {
  font-size: 30rpx;
  font-weight: 700;
}

.emptyDesc {
  margin-top: 10rpx;
  font-size: 26rpx;
}

.btn {
  margin-top: 18rpx;
  display: inline-block;
  padding: 18rpx 24rpx;
}

