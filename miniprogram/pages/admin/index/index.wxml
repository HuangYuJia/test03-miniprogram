<view class="container">
  <view wx:if="{{authLoading}}" class="card deny">
    <view class="denyTitle">校验中…</view>
    <view class="denyDesc muted">正在确认管理员权限，请稍等。</view>
  </view>

  <view wx:elif="{{!isAdmin}}" class="card deny">
    <view class="denyTitle">无权限</view>
    <view class="denyDesc muted">
      你当前还不是管理员。请先复制你的 openid，并在数据库 `admins` 集合中写入。
    </view>

    <button class="btn-ghost" bindtap="copyOpenId">复制我的 openid</button>
    <view class="btn btn-primary" bindtap="goHome">返回首页</view>
  </view>

  <view wx:else>
    <view class="actions card">
      <view class="btn-primary actionBtn" bindtap="goProductNew">新增商品</view>
      <view class="btn-ghost actionBtn" bindtap="goCategoryManage">分类管理</view>
    </view>

    <view class="sectionHeader">
      <view class="sectionTitle">商品列表</view>
      <view class="sectionRight muted">{{countText}}</view>
    </view>

    <view class="filterRow card">
      <button
        class="filterBtn {{listFilter === 'all' ? 'filterBtnActive' : ''}}"
        data-filter="all"
        bindtap="onListFilter"
      >
        全部
      </button>
      <button
        class="filterBtn {{listFilter === 'on' ? 'filterBtnActive' : ''}}"
        data-filter="on"
        bindtap="onListFilter"
      >
        上架
      </button>
      <button
        class="filterBtn {{listFilter === 'off' ? 'filterBtnActive' : ''}}"
        data-filter="off"
        bindtap="onListFilter"
      >
        下架
      </button>
    </view>

    <view wx:if="{{loading}}" class="muted">加载中…</view>

    <view wx:elif="{{items.length === 0 && productTotalCount === 0}}" class="card empty">
      <view class="emptyTitle">还没有商品</view>
      <view class="emptyDesc muted">点上面的“新增商品”上传图片并填写价格。</view>
    </view>

    <view wx:elif="{{items.length === 0}}" class="card empty">
      <view class="emptyTitle">当前筛选下没有商品</view>
      <view class="emptyDesc muted">可点「全部」查看全部商品。</view>
    </view>

    <view wx:else class="list">
      <view wx:for="{{items}}" wx:key="_id" class="row card">
        <image
          class="thumb"
          mode="aspectFill"
          src="{{item.coverDisplaySrc}}"
          data-idx="{{index}}"
          data-fileid="{{item.coverFileId || (item.imageFileIds && item.imageFileIds[0])}}"
          binderror="onThumbError"
        ></image>
        <view class="rowMain">
          <view class="rowTitle">
            <view class="name">{{item.name}}</view>
            <view class="status" data-enabled="{{item.enabled}}">
              {{item.enabled ? "已上架" : "已下架"}}
            </view>
          </view>
          <view class="rowSub muted">{{item.categoryName}}<text wx:if="{{item.unit}}"> {{item.unit}}</text></view>
          <view class="rowBtns">
            <view class="smallBtn btn-ghost" data-id="{{item._id}}" bindtap="goEditProduct">编辑</view>
            <button
              class="smallBtn {{item.enabled ? 'btn-ghost' : 'btn-primary'}}"
              data-id="{{item._id}}"
              data-enabled="{{item.enabled}}"
              bindtap="toggle"
            >
              {{item.enabled ? "下架" : "上架"}}
            </button>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

