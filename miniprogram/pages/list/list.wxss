.bar {
  padding: 18rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}

.barTitle {
  font-size: 30rpx;
  font-weight: 700;
}

.barSub {
  margin-top: 6rpx;
  font-size: 24rpx;
}

.barBtn {
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 39, 0.06);
  color: #111827;
  font-size: 26rpx;
}

.grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.item {
  overflow: hidden;
}

.cover {
  width: 100%;
  height: 320rpx;
  background: rgba(17, 24, 39, 0.06);
}

.meta {
  padding: 14rpx 14rpx 16rpx;
}

.line {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  font-size: 26rpx;
  line-height: 1.35;
}

.line + .line {
  margin-top: 6rpx;
}

.k {
  color: rgba(11, 18, 32, 0.62);
  white-space: nowrap;
}

.v {
  color: #111827;
  font-weight: 700;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  word-break: break-all;
}

.empty {
  margin-top: 16rpx;
  padding: 28rpx 22rpx;
}

.emptyTitle {
  font-size: 30rpx;
  font-weight: 700;
}

.emptyDesc {
  margin-top: 10rpx;
  font-size: 26rpx;
}

