.media {
  overflow: hidden;
  margin-top: 8rpx;
}

.swiper {
  width: 100%;
  height: 720rpx;
}

.img {
  width: 100%;
  height: 720rpx;
  background: rgba(17, 24, 39, 0.06);
}

.info {
  margin-top: 16rpx;
  padding: 22rpx;
}

.kvLine {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  font-size: 28rpx;
  line-height: 1.35;
}

.kvLine + .kvLine {
  margin-top: 10rpx;
}

.k {
  color: rgba(11, 18, 32, 0.62);
  white-space: nowrap;
}

.v {
  color: #111827;
  font-weight: 800;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  word-break: break-all;
}

.tags {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 39, 0.06);
  font-size: 22rpx;
}

.desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  white-space: pre-wrap;
  line-height: 1.6;
}

.actions {
  margin-top: 16rpx;
  padding: 18rpx;
  display: flex;
  gap: 12rpx;
}

.actionBtn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 84rpx;
  font-size: 28rpx;
  text-align: center;
  box-sizing: border-box;
}

.contact {
  margin-top: 16rpx;
  margin-bottom: 32rpx;
  padding: 22rpx;
}

.contactTitle {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.contactLine {
  font-size: 26rpx;
  line-height: 1.7;
}

.empty {
  margin-top: 16rpx;
  padding: 28rpx 22rpx;
}

.emptyTitle {
  font-size: 30rpx;
  font-weight: 700;
}

.btn {
  margin-top: 18rpx;
  display: inline-block;
  padding: 18rpx 24rpx;
}

